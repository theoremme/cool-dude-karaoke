{
  "name": "cool-dude-karaoke",
  "version": "2.0.0",
  "description": "Karaoke playlist desktop application for YouTube videos",
  "main": "main.js",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "pack": "webpack --mode production && electron-builder --dir",
    "dist": "webpack --mode production && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "electron-store": "^11.0.2",
    "jspdf": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  },
  "build": {
    "appId": "com.cooldude.karaoke",
    "productName": "Cool Dude Karaoke",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/config/**/*",
      "src/services/**/*",
      "src/assets/**/*",
      "main.js",
      "preload.js",
      "webview-preload.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src/assets/cool-dude-karaoke-logo-v2.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "src/assets/cool-dude-karaoke-logo-v2.png",
      "category": "public.app-category.entertainment"
    }
  }
}
